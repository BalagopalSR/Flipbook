# Required — use a hosted Postgres database (SQLite does not work on Vercel).
# Neon (free): https://neon.tech — copy the connection string from the dashboard.
# Example:
# DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/flipbook?sslmode=require"
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

JWT_SECRET="change-this-to-a-long-random-string-in-production"
AUTH_USERNAME="admin"
AUTH_PASSWORD="admin123"
