# Login (no database required)
JWT_SECRET="change-this-to-a-long-random-string-in-production"
AUTH_USERNAME="admin"
AUTH_PASSWORD="admin123"

# Vercel Blob storage (required on Vercel — auto-created when you add Blob to the project)
# Vercel Dashboard → Storage → Blob → Connect to project
BLOB_READ_WRITE_TOKEN=""

# Local development: leave BLOB_READ_WRITE_TOKEN empty.
# Flipbooks are saved to data/flipbooks/ on disk automatically.
